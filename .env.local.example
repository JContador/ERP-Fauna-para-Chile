# Copia este archivo como ".env.local" y completa los valores reales.
# ".env.local" NUNCA se sube a GitHub (ya está en .gitignore).
# Estos valores se obtienen desde el panel de Supabase del proyecto de STAGING
# (probamos siempre en staging primero, segun la regla R3 del plan).

# Panel de Supabase > Project Settings > Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Panel de Supabase > Project Settings > Data API > "service_role" (secreta, solo servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Panel de Supabase > Connect > Connection string > "Transaction pooler" (modo URI)
# Reemplaza [YOUR-PASSWORD] por la contraseña que generaste al crear el proyecto.
DATABASE_URL=
